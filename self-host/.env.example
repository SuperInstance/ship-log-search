# ─── Ship Log Search — environment variables ─────────────────────────────────
# Copy this file to `.env` and edit. Do NOT commit `.env` to git.

# ─── Cloudflare (required for /api/search) ───────────────────────────────────
# Account ID: visible at https://dash.cloudflare.com/?to=/:account/workers/ai
CLOUDFLARE_ACCOUNT_ID=

# API token: https://dash.cloudflare.com/profile/api-tokens
# Required scopes: Workers AI:Read, Vectorize:Edit
CLOUDFLARE_API_TOKEN=

# ─── Write key for POST /api/log ─────────────────────────────────────────────
# Anyone with this key can write log entries. Generate with:
#     openssl rand -hex 16
# Leave blank to run the worker in open-write dev mode (no auth on writes).
LOG_KEY=

# ─── Optional overrides ──────────────────────────────────────────────────────
# Host port the worker is exposed on (default 8787).
WORKER_PORT=8787

# Public URL the UI uses to call the API. Set this to the nav computer's
# LAN hostname or IP if you'll access the UI from a phone or tablet:
#     PUBLIC_URL=http://nav-pc.local:8787
PUBLIC_URL=http://localhost:8787

# Signal K server (only used when started with --profile with-signalk)
SIGNALK_PORT=3000